# Generic loop0 CLI provider key.
LOOPS_OPENAI_API_KEY=

# DeepSeek demo defaults used by `uv run loops-demo`.
LOOPS_DEEPSEEK_API_KEY=
LOOPS_DEEPSEEK_BASE_URL=https://api.deepseek.com
LOOPS_DEEPSEEK_MODEL=deepseek-v4-pro
LOOPS_DEEPSEEK_DISABLE_VERIFY_SSL=false

# Optional runtime logging level, e.g. INFO or DEBUG.
LOOPS_LOG_LEVEL=
