{
  "tools": ["shell"],
  "prompt": {
    "system_file": "prompts/loop0-system.md",
    "user": "{{ input.text }}"
  },
  "provider": {
    "type": "openai-compatible",
    "name": "deepseek-v4-pro",
    "model": "deepseek-v4-pro",
    "api_key_env": "LOOPS_DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com/",
    "timeout_seconds": 60,
    "headers": {},
    "extra_body": {}
  },
  "agent": {
    "name": "loop0-cli-example",
    "description": "Example loop0 CLI agent",
    "workspace": "..",
    "metadata": {
      "example": "json-config"
    }
  },
  "policy": {
    "max_turns": 8,
    "allow_tool_errors": true,
    "parallel_tool_calls": true,
    "max_parallel_tool_calls": 4,
    "auto_approve": false,
    "shell_timeout_seconds": 60,
    "shell_max_output_chars": 30000,
    "shell_require_approval_for_background": true,
    "shell_external_path_policy": "ask"
  },
  "run": {
    "input": "Use shell.run from the configured workspace. First run `pwd` and `find . -maxdepth 1 -mindepth 1 -print | sort`; then summarize the top-level files and directories from the command output.",
    "thread_id": "example",
    "stream": true
  },
  "interaction": {
    "source": "cli",
    "interactive": false,
    "raw": {
      "config": "examples/loop0.config.json"
    }
  },
  "output": {
    "format": "text",
    "show_events": false,
    "events_file": "../.loops-example-workspace/events.jsonl"
  }
}
